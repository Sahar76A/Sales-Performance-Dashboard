DimDate =
VAR MinDate = MIN ( FactSales[Order Date] )
VAR MaxDate = MAX ( FactSales[Order Date] )
RETURN
ADDCOLUMNS (
    CALENDAR ( MinDate, MaxDate ),
    "Year", YEAR ( [Date] ),
    "Quarter", "Q" & FORMAT ( [Date], "Q" ),
    "MonthNum", MONTH ( [Date] ),
    "Month", FORMAT ( [Date], "MMM" ),
    "Month Year", FORMAT ( [Date], "MMM YYYY" )
)
